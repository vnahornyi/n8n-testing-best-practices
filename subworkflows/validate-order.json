        "jsCode": "const { z } = require('zod');\n\nconst OrderSchema = z.object({\n  orderId: z\n    .string()\n    .min(1),\n\n  email: z\n    .string()\n    .email(),\n\n  amount: z\n    .number()\n    .positive(),\n\n  dryRun: z\n    .boolean()\n    .optional()\n    .default(false)\n});\n\nconst data = $input.first().json;\n\nconst parsed = OrderSchema.safeParse(data);\n\nif (!parsed.success) {\n  throw new Error(\n    JSON.stringify(parsed.error.flatten())\n  );\n}\n\nreturn [\n  {\n    json: parsed.data\n  }\n];"
